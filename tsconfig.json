{
  "compilerOptions": {
    "target": "ES2020",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "paths": {
      "@signe/sync": ["./packages/sync/src/index.ts"],
      "@signe/reactive": ["./packages/reactive/src/index.ts"]
    },
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["packages/*/src/**/*.ts"],
  "exclude": [
    "**/dist/**",
    "node_modules",
    "packages/**/examples/**",
    "tests/**"
  ]
}
