{
  "name": "@signe/reactive",
  "version": "2.9.2",
  "description": "Small signal-based reactivity primitives with observable object and array changes.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts",
    "dev": "tsup src/index.ts --watch"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": "./*"
  },
  "keywords": [
    "signals",
    "reactive",
    "rxjs",
    "typescript"
  ],
  "author": "Samuel Ronce",
  "license": "MIT",
  "dependencies": {
    "rxjs": "^7.8.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^22.13.9"
  }
}
