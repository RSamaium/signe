{
  "name": "@signe/di",
  "version": "3.0.1",
  "description": "Lightweight dependency injection container for TypeScript applications.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts",
    "dev": "tsup src/index.ts --watch"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": "./*"
  },
  "keywords": [
    "dependency-injection",
    "di",
    "typescript"
  ],
  "author": "Samuel Ronce",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module"
}
