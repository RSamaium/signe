{
  "name": "@signe/room",
  "version": "2.10.0",
  "description": "PartyKit room primitives with synchronized state, sessions, guards, and HTTP handlers.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/node/index.ts",
    "dev": "tsup src/index.ts src/node/index.ts --watch"
  },
  "keywords": [
    "partykit",
    "realtime",
    "websocket",
    "cloudflare",
    "typescript"
  ],
  "author": "Samuel Ronce",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node/index.js",
      "types": "./dist/node/index.d.ts"
    }
  },
  "license": "MIT",
  "dependencies": {
    "dset": "^3.1.3",
    "partysocket": "^1.0.1",
    "zod": "^3.23.8",
    "@signe/sync": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240603.0",
    "@types/node": "^22.13.9"
  }
}
