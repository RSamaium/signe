{
  "name": "@signe/schema-to-zod",
  "version": "2.9.2",
  "description": "Convert JSON Schema definitions into Zod schemas.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts",
    "dev": "tsup src/index.ts --watch"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": "./*"
  },
  "keywords": [
    "json-schema",
    "zod",
    "validation",
    "typescript"
  ],
  "author": "Samuel Ronce",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "dependencies": {
    "@types/json-schema": "^7.0.15"
  }
}
